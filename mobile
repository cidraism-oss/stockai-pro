    });
    
    document.getElementById('m-side-nav').innerHTML = html;
}

// ============ NAVIGATION ============
function mNavigate(page) {
    M.currentPage = page;
    
    // Update nav
    document.querySelectorAll('.m-nav-item').forEach(function(item) {
        item.classList.toggle('active', item.dataset.page === page);
    });
    
    // Update header title
    var titles = {dashboard:'Dashboard','stock-count':'Stock Count',purchases:'Purchases',inventory:'Inventory',reports:'Reports',notifications:'Notifications'};
    document.getElementById('m-page-title').textContent = titles[page] || page;
    
    // Show/hide voice FAB
    var fab = document.getElementById('m-voice-fab');
    if (page === 'stock-count') fab.classList.remove('hidden');
    else fab.classList.add('hidden');
    
    // Render page
    var content = document.getElementById('m-content');
    content.scrollTop = 0;
    
    if (page === 'dashboard') content.innerHTML = mPageDashboard();
    else if (page === 'stock-count') content.innerHTML = mPageStockCount();
    else if (page === 'purchases') content.innerHTML = mPagePurchases();
    else if (page === 'inventory') content.innerHTML = mPageInventory();
    else if (page === 'reports') content.innerHTML = mPageReports();
    else if (page === 'notifications') content.innerHTML = mPageNotifications();
    
    buildSideMenu();
}

function toggleSideMenu() {
    document.getElementById('m-side-menu').classList.toggle('open');
}

// ============ FILTER BY CATEGORY ============
function mFilterCats(items) {
    var perms = PERMS[M.user.role] || {};
    if (perms.categories && perms.categories !== 'all') {
        return items.filter(function(i) { return perms.categories.indexOf(i.category) !== -1; });
    }
    return items;
}

