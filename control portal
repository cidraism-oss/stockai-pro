let selectedUpgradePlan = '';
function selectUpgradePlan(el, plan) {
    document.querySelectorAll('#upgrade-plans .plan-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    selectedUpgradePlan = plan;
}

function confirmPlanChange(entityId) {
    const ent = P.entities.find(e => e.id === entityId);
    if (!ent) return;
    
    if (!document.getElementById('upgrade-agree').checked) {
        toast('error', 'Please accept the 30-day notice period disclaimer');
        return;
    }
    
    if (!selectedUpgradePlan || selectedUpgradePlan === ent.plan) {
        toast('info', 'Please select a different plan');
        return;
    }
    
    const oldPlan = PLANS[ent.plan];
    const newPlan = PLANS[selectedUpgradePlan];
    const isUpgrade = newPlan.price > oldPlan.price;
    const changeType = isUpgrade ? 'Upgrade' : 'Downgrade';
    const effectiveDate = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toLocaleDateString('en-ZA', {day:'2-digit', month:'long', year:'numeric'});
    
    if (!confirm(`Confirm ${changeType}:\n\n🏢 Entity: ${ent.name}\n📋 From: ${oldPlan.name} (R${oldPlan.price}/mo)\n📋 To: ${newPlan.name} (R${newPlan.price}/mo)\n\n⏰ 30-day notice applies\n📅 Effective date: ${effectiveDate}\n\nProceed?`)) return;
    
    ent.plan = selectedUpgradePlan;
    ent.planChangeDate = new Date().toISOString();
    ent.planEffectiveDate = effectiveDate;
    ent.planChangeType = changeType;
    
    // Send confirmation emails
    sendNotificationEmail('plan_change', {
        entityName: ent.name,
        oldPlan: oldPlan.name,
        newPlan: newPlan.name,
        changeType: changeType,
        effectiveDate: effectiveDate
    });
    
    // Notify web app
    notifyWebApp('plan_changed', {
        entityId: ent.id,
        newPlan: selectedUpgradePlan,
        changeType: changeType
    });
    
    savePortal();
    closePortalModal();
    renderPortalStats();
    renderEntities();
    
    toast('success', `✅ ${changeType} confirmed! ${newPlan.name} plan takes effect ${isUpgrade ? 'immediately' : 'on ' + effectiveDate}. Confirmation emails sent.`);
}

