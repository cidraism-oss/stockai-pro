<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0d4a5c">
<meta name="mobile-web-app-capable" content="yes">
<title>StockAI-Pro Mobile</title>
<link rel="manifest" href="/manifest.json">
<link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%230d4a5c' width='100' height='100' rx='20'/><text x='50' y='68' text-anchor='middle' fill='white' font-size='45' font-weight='bold' font-family='Arial'>AI</text></svg>">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<style>
:root{--primary:#1a8ba8;--primary-dark:#0d4a5c;--primary-light:#4dbdd5;--bg:#f0f7f9;--bg-card:#fff;--text:#0d4a5c;--text-mid:#2a5f70;--text-light:#5a8a96;--text-muted:#8aabb5;--gold:#f59e0b;--success:#2ea871;--danger:#c94545;--warning:#d4a017;--info:#2b8eb3;--border:#c4dde4;--shadow:0 2px 12px rgba(13,74,92,.08);--shadow-lg:0 8px 30px rgba(13,74,92,.15);--r:12px;--rs:8px;--nav-h:60px;--header-h:56px}

/* AUTO DARK MODE */
@media(prefers-color-scheme:dark){
:root{--bg:#0a1a1f;--bg-card:#0f2a33;--text:#e0f0f4;--text-mid:#a0c8d4;--text-light:#6a9aaa;--text-muted:#4a7a8a;--border:#1a3a44;--shadow:0 2px 12px rgba(0,0,0,.3);--shadow-lg:0 8px 30px rgba(0,0,0,.4)}
.dark-override{background:var(--bg)!important;color:var(--text)!important}
}

*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden}
body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--text);font-size:14px;position:relative;user-select:none;-webkit-user-select:none}
.hidden{display:none!important}

/* SPLASH */
.splash{position:fixed;inset:0;background:linear-gradient(135deg,var(--primary-dark),var(--primary));display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:99999;transition:opacity .5s ease}
.splash-logo{width:80px;height:80px;background:#fff;border-radius:18px;display:flex;align-items:center;justify-content:center;color:var(--primary-dark);font-size:2.2rem;margin-bottom:16px;box-shadow:0 8px 30px rgba(0,0,0,.2);animation:splashPulse 2s ease-in-out infinite}
@keyframes splashPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
.splash h1{color:#fff;font-size:1.8rem;font-weight:900;letter-spacing:2px}
.splash p{color:rgba(255,255,255,.8);font-size:.85rem;font-style:italic;margin-top:4px}
.splash-loader{width:40px;height:40px;border:3px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:spin 1s linear infinite;margin-top:30px}
@keyframes spin{to{transform:rotate(360deg)}}

/* LOGIN */
.m-login{position:fixed;inset:0;background:linear-gradient(135deg,var(--primary-dark),var(--primary));display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;z-index:9999}
.m-login-card{background:#fff;border-radius:20px;padding:32px 24px;width:100%;max-width:380px;box-shadow:0 20px 60px rgba(0,0,0,.3);text-align:center}
.m-login-logo{width:56px;height:56px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));border-radius:14px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.5rem;margin:0 auto 14px}
.m-login-card h2{font-size:1.3rem;font-weight:800;color:var(--text);margin-bottom:3px}
.m-login-card .sub{font-size:.82rem;color:var(--text-light);margin-bottom:20px}
.m-input{width:100%;padding:14px 16px;border:1px solid var(--border);border-radius:var(--rs);font-size:.95rem;font-family:inherit;color:var(--text);margin-bottom:12px;transition:.2s;background:var(--bg)}
.m-input:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px rgba(26,139,168,.15)}
.m-select{width:100%;padding:14px 16px;border:1px solid var(--border);border-radius:var(--rs);font-size:.95rem;font-family:inherit;color:var(--text);margin-bottom:12px;background:var(--bg);appearance:none;-webkit-appearance:none}
.m-btn{width:100%;padding:14px;border:none;border-radius:var(--rs);font-size:1rem;font-weight:700;cursor:pointer;font-family:inherit;transition:.3s}
.m-btn-primary{background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff}
.m-btn-primary:active{transform:scale(.97)}

/* APP SHELL */
.m-app{position:fixed;inset:0;display:flex;flex-direction:column;background:var(--bg)}

/* HEADER */
.m-header{height:var(--header-h);background:linear-gradient(90deg,var(--primary-dark),var(--primary));display:flex;align-items:center;padding:0 16px;gap:12px;flex-shrink:0;box-shadow:0 2px 12px rgba(0,0,0,.15);z-index:50}
.m-header-menu{width:36px;height:36px;background:rgba(255,255,255,.15);border:none;border-radius:var(--rs);color:#fff;font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center}
.m-header-title{flex:1;color:#fff;font-size:.95rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.m-header-entity{font-size:.65rem;color:rgba(255,255,255,.7);display:block;font-weight:400}
.m-header-actions{display:flex;gap:8px}
.m-header-btn{width:36px;height:36px;background:rgba(255,255,255,.15);border:none;border-radius:var(--rs);color:#fff;font-size:.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;position:relative}
.m-header-btn .badge{position:absolute;top:-2px;right:-2px;width:16px;height:16px;background:var(--danger);border-radius:50%;font-size:.55rem;font-weight:700;display:flex;align-items:center;justify-content:center;color:#fff}

/* CONTENT AREA */
.m-content{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;padding:16px;padding-bottom:calc(var(--nav-h) + 16px)}

/* BOTTOM NAV */
.m-nav{height:var(--nav-h);background:var(--bg-card);border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-around;flex-shrink:0;padding:0 8px;box-shadow:0 -2px 12px rgba(0,0,0,.05);z-index:50}
.m-nav-item{display:flex;flex-direction:column;align-items:center;gap:2px;padding:8px 12px;border-radius:var(--rs);cursor:pointer;transition:.2s;color:var(--text-light);min-width:56px}
.m-nav-item.active{color:var(--primary);background:rgba(26,139,168,.08)}
.m-nav-item i{font-size:1.2rem}
.m-nav-item span{font-size:.62rem;font-weight:600;letter-spacing:.3px}

/* SIDE MENU */
.m-side-menu{position:fixed;inset:0;z-index:200;pointer-events:none}
.m-side-menu.open{pointer-events:all}
.m-side-overlay{position:absolute;inset:0;background:rgba(0,0,0,.5);opacity:0;transition:opacity .3s}
.m-side-menu.open .m-side-overlay{opacity:1}
.m-side-panel{position:absolute;left:0;top:0;bottom:0;width:280px;background:var(--bg-card);box-shadow:var(--shadow-lg);transform:translateX(-100%);transition:transform .3s ease;overflow-y:auto}
.m-side-menu.open .m-side-panel{transform:translateX(0)}
.m-side-header{background:linear-gradient(135deg,var(--primary-dark),var(--primary));padding:24px 20px;color:#fff}
.m-side-header h3{font-size:1.1rem;font-weight:800}
.m-side-header p{font-size:.78rem;opacity:.85;margin-top:2px}
.m-side-nav{padding:12px}
.m-side-link{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:var(--rs);color:var(--text-mid);font-size:.9rem;font-weight:500;cursor:pointer;transition:.2s;margin-bottom:4px}
.m-side-link:hover,.m-side-link.active{background:rgba(26,139,168,.08);color:var(--primary)}
.m-side-link i{width:20px;text-align:center;color:var(--primary);font-size:.95rem}
.m-side-divider{height:1px;background:var(--border);margin:10px 14px}
.m-side-footer{padding:16px 20px;border-top:1px solid var(--border)}

/* CARDS */
.m-card{background:var(--bg-card);border-radius:var(--r);padding:16px;box-shadow:var(--shadow);margin-bottom:12px;position:relative;border-left:4px solid var(--primary)}
.m-card-title{font-size:.9rem;font-weight:700;color:var(--text);margin-bottom:8px;display:flex;align-items:center;gap:8px}
.m-card-title i{color:var(--primary)}

/* STAT CARDS */
.m-stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.m-stat{background:var(--bg-card);border-radius:var(--r);padding:14px;box-shadow:var(--shadow);border-left:3px solid var(--primary)}
.m-stat small{font-size:.65rem;color:var(--text-light);text-transform:uppercase;letter-spacing:.5px;font-weight:600;display:block;margin-bottom:3px}
.m-stat strong{font-size:1.3rem;font-weight:800;color:var(--text);display:block}
.m-stat.gold{border-left-color:var(--gold)}
.m-stat.green{border-left-color:var(--success)}
.m-stat.red{border-left-color:var(--danger)}

/* QUICK ACTIONS */
.m-quick-actions{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}
.m-quick-btn{background:var(--bg-card);border-radius:var(--r);padding:14px 8px;text-align:center;box-shadow:var(--shadow);cursor:pointer;transition:.2s;border:none;font-family:inherit}
.m-quick-btn:active{transform:scale(.95);background:rgba(26,139,168,.08)}
.m-quick-btn i{font-size:1.4rem;color:var(--primary);display:block;margin-bottom:6px}
.m-quick-btn span{font-size:.65rem;color:var(--text-mid);font-weight:600;display:block;line-height:1.2}

/* LIST ITEMS */
.m-list-item{display:flex;align-items:center;gap:12px;padding:12px 14px;background:var(--bg-card);border-radius:var(--rs);margin-bottom:8px;box-shadow:var(--shadow);cursor:pointer;transition:.2s}
.m-list-item:active{background:rgba(26,139,168,.05)}
.m-list-icon{width:38px;height:38px;border-radius:10px;background:rgba(26,139,168,.1);display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:1rem;flex-shrink:0}
.m-list-info{flex:1;min-width:0}
.m-list-info h4{font-size:.88rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.m-list-info p{font-size:.72rem;color:var(--text-light)}
.m-list-badge{padding:3px 10px;border-radius:12px;font-size:.65rem;font-weight:600;flex-shrink:0}
.m-list-badge.green{background:rgba(46,168,113,.12);color:var(--success)}
.m-list-badge.orange{background:rgba(245,158,11,.12);color:var(--gold)}
.m-list-badge.red{background:rgba(201,69,69,.12);color:var(--danger)}

/* STOCK COUNT */
.m-count-item{display:flex;align-items:center;gap:10px;padding:14px;background:var(--bg-card);border-radius:var(--rs);margin-bottom:8px;box-shadow:var(--shadow)}
.m-count-info{flex:1}
.m-count-info h4{font-size:.88rem;font-weight:600;color:var(--text)}
.m-count-info p{font-size:.68rem;color:var(--text-light)}
.m-count-input{width:70px;padding:10px 8px;text-align:center;border:2px solid var(--border);border-radius:var(--rs);font-size:1.1rem;font-weight:700;font-family:inherit;color:var(--text);background:var(--bg)}
.m-count-input:focus{outline:none;border-color:var(--primary)}
.m-count-variance{min-width:40px;text-align:center;font-size:.82rem;font-weight:700;padding:4px 8px;border-radius:var(--rs)}
.m-count-variance.pos{color:var(--success);background:rgba(46,168,113,.1)}
.m-count-variance.neg{color:var(--danger);background:rgba(201,69,69,.1)}
.m-count-variance.zero{color:var(--text-muted)}

/* VOICE BUTTON */
.m-voice-fab{position:fixed;bottom:calc(var(--nav-h) + 20px);right:20px;width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border:none;font-size:1.5rem;cursor:pointer;box-shadow:0 6px 24px rgba(26,139,168,.4);z-index:40;display:flex;align-items:center;justify-content:center;transition:.3s}
.m-voice-fab:active{transform:scale(.9)}
.m-voice-fab.listening{background:linear-gradient(135deg,var(--danger),#a83232);animation:fabPulse 1.5s ease-in-out infinite}
@keyframes fabPulse{0%,100%{box-shadow:0 0 0 0 rgba(201,69,69,.4)}50%{box-shadow:0 0 0 15px rgba(201,69,69,0)}}

/* VOICE OVERLAY */
.m-voice-overlay{position:fixed;inset:0;background:rgba(13,74,92,.9);backdrop-filter:blur(10px);z-index:300;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;color:#fff;text-align:center}
.m-voice-circle{width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--primary-dark));display:flex;align-items:center;justify-content:center;font-size:2.5rem;margin-bottom:20px;position:relative}
.m-voice-ring{position:absolute;inset:-10px;border:2px solid var(--primary-light);border-radius:50%;animation:vring 2s ease-out infinite}
.m-voice-ring:nth-child(2){animation-delay:.5s;inset:-20px}
@keyframes vring{0%{transform:scale(.8);opacity:1}100%{transform:scale(1.3);opacity:0}}
.m-voice-overlay h2{font-size:1.3rem;font-weight:700;margin-bottom:6px}
.m-voice-overlay .transcript{font-size:1rem;color:var(--primary-light);min-height:30px;margin-bottom:16px}
.m-voice-overlay .hint{font-size:.82rem;opacity:.7;margin-bottom:20px;padding:10px;background:rgba(255,255,255,.08);border-radius:var(--rs)}

/* AI CHAT */
.m-ai-overlay{position:fixed;inset:0;background:var(--bg);z-index:250;display:flex;flex-direction:column}
.m-ai-header{height:var(--header-h);background:linear-gradient(90deg,var(--primary-dark),var(--primary));display:flex;align-items:center;padding:0 16px;gap:12px;flex-shrink:0}
.m-ai-avatar{width:36px;height:36px;background:rgba(255,255,255,.2);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1rem}
.m-ai-header h3{color:#fff;font-size:.95rem;font-weight:700;flex:1}
.m-ai-header span{color:rgba(255,255,255,.7);font-size:.7rem}
.m-ai-messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px}
.m-ai-msg{max-width:85%;padding:12px 16px;border-radius:14px;font-size:.88rem;line-height:1.5}
.m-ai-msg.bot{align-self:flex-start;background:var(--bg-card);color:var(--text);border-bottom-left-radius:4px;box-shadow:var(--shadow)}
.m-ai-msg.user{align-self:flex-end;background:var(--primary);color:#fff;border-bottom-right-radius:4px}
.m-ai-msg ul{margin:6px 0;padding-left:16px}
.m-ai-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.m-ai-chip{padding:6px 12px;background:var(--bg);border:1px solid var(--border);border-radius:16px;font-size:.75rem;color:var(--text);cursor:pointer;font-family:inherit}
.m-ai-input-bar{display:flex;gap:8px;padding:12px 16px;border-top:1px solid var(--border);background:var(--bg-card);flex-shrink:0}
.m-ai-input{flex:1;padding:12px 16px;border:1px solid var(--border);border-radius:24px;font-size:.9rem;font-family:inherit;color:var(--text);background:var(--bg);outline:none}
.m-ai-send{width:44px;height:44px;border-radius:50%;background:var(--primary);color:#fff;border:none;font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center}

/* SEARCH */
.m-search{display:flex;align-items:center;gap:8px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r);padding:10px 14px;margin-bottom:12px}
.m-search i{color:var(--text-muted)}
.m-search input{flex:1;border:none;outline:none;font-size:.9rem;font-family:inherit;color:var(--text);background:transparent}

/* SECTION HEADERS */
.m-section-title{font-size:.82rem;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin:14px 0 8px;padding-left:4px}

/* PULL TO REFRESH */
.m-ptr{text-align:center;padding:10px;color:var(--text-light);font-size:.82rem;display:none}

/* ALERTS */
.m-alert{padding:12px 16px;border-radius:var(--rs);margin-bottom:10px;display:flex;align-items:flex-start;gap:10px;font-size:.85rem}
.m-alert.warning{background:rgba(212,160,23,.08);border-left:3px solid var(--warning);color:var(--text)}
.m-alert.danger{background:rgba(201,69,69,.08);border-left:3px solid var(--danger);color:var(--text)}
.m-alert.success{background:rgba(46,168,113,.08);border-left:3px solid var(--success);color:var(--text)}
.m-alert i{margin-top:2px;flex-shrink:0}

/* PAYMENT MODAL */
.m-payment-overlay{position:fixed;inset:0;background:rgba(13,74,92,.8);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px}
.m-payment-modal{background:#fff;border-radius:20px;width:100%;max-width:400px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.3)}
.m-payment-header{padding:24px;text-align:center}
.m-payment-header.warning{background:linear-gradient(135deg,#fff8e1,#fff3cd)}
.m-payment-header.danger{background:linear-gradient(135deg,#fee2e2,#fecaca)}
.m-payment-header h2{font-size:1.2rem;font-weight:800;color:var(--text);margin-top:10px}
.m-payment-header p{font-size:.85rem;color:var(--text-mid);margin-top:6px;line-height:1.4}
.m-payment-body{padding:16px 24px}
.m-payment-amount{text-align:center;font-size:2rem;font-weight:900;color:var(--primary);margin:10px 0}
.m-payment-footer{padding:16px 24px 24px;display:flex;gap:10px}
.m-payment-footer button{flex:1;padding:14px;border-radius:var(--rs);font-weight:700;cursor:pointer;font-family:inherit;border:none;font-size:.92rem}

/* TOAST */
.m-toast-wrap{position:fixed;top:calc(var(--header-h) + 10px);left:16px;right:16px;z-index:500;display:flex;flex-direction:column;gap:8px}
.m-toast{padding:12px 16px;border-radius:var(--rs);box-shadow:var(--shadow-lg);display:flex;align-items:center;gap:10px;animation:slideDown .3s ease;font-size:.85rem;font-weight:500}
@keyframes slideDown{from{transform:translateY(-20px);opacity:0}to{transform:translateY(0);opacity:1}}
.m-toast.success{background:#d1fae5;color:#065f46;border-left:3px solid var(--success)}
.m-toast.error{background:#fee2e2;color:#991b1b;border-left:3px solid var(--danger)}
.m-toast.info{background:#d4f0f7;color:#0d4a5c;border-left:3px solid var(--info)}
.m-toast.warning{background:#fef3c7;color:#92400e;border-left:3px solid var(--warning)}
.m-toast span{flex:1}
.m-toast button{background:none;border:none;font-size:.9rem;cursor:pointer;color:inherit;opacity:.6}

/* ENTITY SELECTOR */
.m-entity-screen{position:fixed;inset:0;background:linear-gradient(135deg,var(--primary-dark),var(--primary));z-index:100;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px}
.m-entity-screen h2{color:#fff;font-size:1.3rem;font-weight:800;margin-bottom:4px}
.m-entity-screen p{color:rgba(255,255,255,.8);font-size:.85rem;margin-bottom:20px}
.m-entity-cards{width:100%;max-width:400px;display:flex;flex-direction:column;gap:10px;max-height:60vh;overflow-y:auto}
.m-entity-card{background:#fff;border-radius:var(--r);padding:18px;cursor:pointer;transition:.2s;display:flex;align-items:center;gap:14px}
.m-entity-card:active{transform:scale(.97)}
.m-entity-avatar{width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:700;flex-shrink:0}
.m-entity-card h3{font-size:.95rem;font-weight:700;color:var(--text)}
.m-entity-card p{font-size:.72rem;color:var(--text-light)}
.m-entity-card.global{background:linear-gradient(135deg,#1a1a2e,#0f3460);border:2px solid var(--gold)}
.m-entity-card.global h3{color:#fff}
.m-entity-card.global p{color:var(--gold)}
.m-entity-card.global .m-entity-avatar{background:var(--gold);color:#1a1a2e}

/* EMPTY STATE */
.m-empty{text-align:center;padding:40px 20px;color:var(--text-light)}
.m-empty i{font-size:3rem;color:var(--primary);opacity:.3;margin-bottom:14px}
.m-empty h3{font-size:1rem;color:var(--text);margin-bottom:6px}
.m-empty p{font-size:.85rem}

/* REPORT CARD */
.m-report-card{display:flex;align-items:center;gap:12px;padding:16px;background:var(--bg-card);border-radius:var(--r);margin-bottom:10px;box-shadow:var(--shadow);cursor:pointer;border-left:3px solid var(--primary)}
.m-report-card:active{background:rgba(26,139,168,.05)}
.m-report-icon{width:42px;height:42px;background:rgba(26,139,168,.1);border-radius:10px;display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:1.1rem;flex-shrink:0}
.m-report-info h4{font-size:.88rem;font-weight:600;color:var(--text)}
.m-report-info p{font-size:.72rem;color:var(--text-light)}

/* NOTIFICATION ITEMS */
