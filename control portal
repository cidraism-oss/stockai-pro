function purchaseNewEntity() {
    const name = document.getElementById('new-ent-name').value;
    const contact = document.getElementById('new-ent-contact').value;
    if (!name || !contact) { toast('error','Entity name and contact required'); return; }
    
    const plan = PLANS[selectedNewPlan];
    
    // Simulate payment
    if (!confirm(`Confirm purchase:\n\n🏢 Entity: ${name}\n📋 Plan: ${plan.name}\n💰 Amount: R${plan.price}/month\n\nYou will be charged R${plan.price} now.\n\nProceed?`)) return;
    
    const newEntity = {
        id: 'ENT-PORTAL-' + Date.now(),
        name: name,
        plan: selectedNewPlan,
        status: 'active',
        contact: contact,
        email: document.getElementById('new-ent-email').value,
        phone: document.getElementById('new-ent-phone').value,
        createdDate: new Date().toLocaleDateString('en-ZA'),
        pendingSetup: true  // Flag for web app to show "Add New Entity" tab
