        document.getElementById('m-login').classList.add('hidden');
        mToast('info', '🔄 Loading customers...');
        showMobileAdminPanel();
        return;
    }
    
    // Normal mobile login
    M.user = { name: name, role: document.getElementById('m-role').value, assignedEntity: 0 };
    document.getElementById('m-login').classList.add('hidden');
    mToast('info', '🔄 Loading data...');
    
    mLoadFromCloud(function(found) {
        if (found && M.entities.length > 0) {
            mToast('success', '☁️ Data loaded');
            
            // Check if suspended
            var accountId = getMobileAccountId();
            if (accountId) {
                db.collection('accounts').doc(accountId).get().then(function(doc) {
                    if (doc.exists && doc.data().accountStatus === 'suspended') {
                        mToast('error', '⚠️ Account suspended. Contact support.');
                        document.getElementById('m-entity-screen').classList.add('hidden');
                        document.getElementById('m-login').classList.remove('hidden');
                        alert('Your account is suspended.\n\nContact StockAI-Pro:\nWhatsApp: 079 044 0508');
                        return;
                    }
                    showMobileEntitySelector();
                });
            } else {
                showMobileEntitySelector();
            }
        } else if (M.entities.length > 0) {
            showMobileEntitySelector();
        } else {
            M.entities = [{id:'ENT-MOB-'+Date.now(),name:name+'\'s Restaurant',contact:name,phone:'',email:'',address:'',vat:'',foodCostTarget:28,sections:['Walk-in Fridge','Walk-in Freezer','Dry Store','Bar'],plan:'professional'}];
            generateMobileData(M.entities[0]);
            showMobileEntitySelector();
        }
    });
    
    mLogAction('Login', name + ' logged in on mobile');
};

function showMobileAdminPanel() {
    document.getElementById('m-entity-screen').classList.remove('hidden');
    document.getElementById('m-entity-screen').querySelector('h2').textContent = '🔑 Admin Panel';
    document.getElementById('m-entity-screen').querySelector('p').textContent = 'Select a customer to manage';
    
    var cardsEl = document.getElementById('m-entity-cards');
    cardsEl.innerHTML = '<div style="text-align:center;padding:20px;color:#5a8a96"><i class="fas fa-spinner fa-spin" style="font-size:1.3rem"></i><br>Loading customers...</div>';
    
    db.collection('accounts').get()
        .then(function(snapshot) {
            var html = '';
            snapshot.forEach(function(doc) {
                var data = doc.data();
                var isActive = (data.accountStatus || 'active') === 'active';
                var ownerName = data.owner ? data.owner.name : 'Unknown';
                var ownerEmail = data.owner ? data.owner.email : '';
                var entCount = data.entities ? data.entities.length : 0;
                var statusDot = isActive ? '🟢' : '🔴';
                var statusText = isActive ? 'Active' : 'Suspended';
                
                html += '<div class="m-entity-card" onclick="mAdminSelectCustomer(\'' + doc.id + '\')" style="' + (!isActive ? 'opacity:.7;border-left:3px solid #c94545' : '') + '">' +
                    '<div class="m-entity-avatar">' + ownerName.charAt(0) + '</div>' +
                    '<div style="flex:1">' +
                        '<h3>' + ownerName + ' ' + statusDot + '</h3>' +
                        '<p>' + ownerEmail + ' • ' + entCount + ' entities • ' + statusText + '</p>' +
                    '</div>' +
                '</div>';
            });
            
            if (!html) html = '<div style="text-align:center;padding:20px;color:#5a8a96">No customers yet</div>';
            
            html += '<div class="m-entity-card" onclick="mAdminBackToLogin()" style="background:#f5f9fa;border:1px dashed #c4dde4"><div class="m-entity-avatar" style="background:#5a8a96"><i class="fas fa-arrow-left"></i></div><div><h3 style="color:#5a8a96">Back to Login</h3><p>Return to login screen</p></div></div>';
            
            cardsEl.innerHTML = html;
        })
        .catch(function(err) {
            cardsEl.innerHTML = '<div style="text-align:center;padding:20px;color:#c94545">Error: ' + err.message + '</div>';
        });
}

function mAdminSelectCustomer(accountId) {
    mToast('info', '🔄 Loading...');
    
    db.collection('accounts').doc(accountId).get()
        .then(function(doc) {
            if (!doc.exists) { mToast('error', 'Not found'); return; }
            var data = doc.data();
            
            M.entities = data.entities || [];
            M.inventory = data.inventory || {};
            M.purchases = data.purchases || {};
            M.wastage = data.wastage || {};
            M.suppliers = data.suppliers || {};
            M.users = data.users || {};
            M.activities = data.activities || {};
            M.pendingPOs = data.pendingPOs || {};
            M.notifs = data.notifs || [];
            M.billing = data.billing || null;
            M.userLogs = data.userLogs || {};
            
            var name = data.owner ? data.owner.name : accountId;
            mToast('success', '✅ Loaded: ' + name);
            
            if (M.entities.length === 0) {
                mToast('warning', 'No entities for this customer');
                return;
            }
            
            showMobileEntitySelector();
            startMobileSync();
        })
        .catch(function(err) { mToast('error', 'Failed: ' + err.message); });
}

function mAdminBackToLogin() {
    document.getElementById('m-entity-screen').classList.add('hidden');
    document.getElementById('m-login').classList.remove('hidden');
    M.user = null;
}

