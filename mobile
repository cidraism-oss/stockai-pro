function mAIReply(q) {
    var ql = q.toLowerCase();
    var inv = [];
    var entName = 'restaurant';
    
    if (M.isGlobalMode) {
        M.entities.forEach(function(e) { inv = inv.concat(M.inventory[e.id] || []); });
        entName = 'all entities';
    } else if (M.entities[M.activeEntity]) {
        var ent = M.entities[M.activeEntity];
        inv = M.inventory[ent.id] || [];
        entName = ent.name;
    }
    
    inv = mFilterCats(inv);
    
    if (ql.indexOf('low') !== -1) {
        var low = inv.filter(function(i) { return i.status === 'low-stock'; });
        return '📊 <strong>' + low.length + ' low at ' + entName + ':</strong><ul>' + low.slice(0,8).map(function(i) { return '<li>' + i.name + ' — ' + i.quantity + ' ' + i.unit + '</li>'; }).join('') + '</ul>';
    }
    if (ql.indexOf('wastage') !== -1) return '🗑️ Today\'s wastage: <strong>R3,200</strong>';
    if (ql.indexOf('reorder') !== -1) {
        var low2 = inv.filter(function(i) { return i.status === 'low-stock' || i.status === 'out-of-stock'; });
        var t = 0;
        var r = '🛒 Reorder suggestions:<ul>';
        low2.slice(0,8).forEach(function(i) { var c = i.reorder * 3 * i.cost; t += c; r += '<li>' + i.name + ' — ' + (i.reorder * 3) + ' ' + i.unit + '</li>'; });
        return r + '</ul>Total: <strong>R' + t.toFixed(0) + '</strong>';
    }
    if (ql.indexOf('hello') !== -1 || ql.indexOf('hi') !== -1) return '👋 Hello! How can I help with ' + entName + '?';
    if (ql.indexOf('help') !== -1) return '🤖 I can help with: low stock, wastage, reorder suggestions, and more!';
    return '🤔 Try: "low stock", "wastage", "reorder", or "help"';
}

