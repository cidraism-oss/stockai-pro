// ============ VOICE STOCK COUNT ============
var mVoiceRecog = null;

function startMobileVoice() {
    if (!('webkitSpeechRecognition' in window || 'SpeechRecognition' in window)) {
        mToast('warning', 'Voice not supported on this device');
        return;
    }
    
    document.getElementById('m-voice-overlay').classList.remove('hidden');
    document.getElementById('m-voice-fab').classList.add('listening');
    document.getElementById('m-voice-transcript').textContent = 'Say "[item name] [quantity]"';
    
    var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    mVoiceRecog = new SR();
    mVoiceRecog.continuous = true;
    mVoiceRecog.interimResults = false;
    mVoiceRecog.lang = 'en-ZA';
    
    mVoiceRecog.onresult = function(e) {
        var transcript = e.results[e.results.length - 1][0].transcript.toLowerCase().trim();
        document.getElementById('m-voice-transcript').textContent = 'Heard: "' + transcript + '"';
        
        if (transcript.includes('stop') || transcript.includes('finish') || transcript.includes('done')) {
            stopMobileVoice();
            mNavigate('stock-count');
            mToast('success', 'Voice count completed');
            return;
        }
        
        processMobileVoiceCount(transcript);
    };
    
    mVoiceRecog.onerror = function() {};
    mVoiceRecog.onend = function() {
        document.getElementById('m-voice-fab').classList.remove('listening');
    };
    
    try { mVoiceRecog.start(); } catch(e) { mToast('error', 'Voice error'); }
}

function stopMobileVoice() {
    document.getElementById('m-voice-overlay').classList.add('hidden');
    document.getElementById('m-voice-fab').classList.remove('listening');
    if (mVoiceRecog) try { mVoiceRecog.stop(); } catch(e) {}
}

function processMobileVoiceCount(transcript) {
    var ent = M.entities[M.activeEntity];
    var inv = mFilterCats(M.inventory[ent.id] || []);
    
    var numberWords = {zero:0,one:1,two:2,three:3,four:4,five:5,six:6,seven:7,eight:8,nine:9,ten:10,eleven:11,twelve:12,thirteen:13,fourteen:14,fifteen:15,sixteen:16,seventeen:17,eighteen:18,nineteen:19,twenty:20,thirty:30,forty:40,fifty:50,sixty:60,seventy:70,eighty:80,ninety:90,hundred:100};
    
    var words = transcript.split(/\s+/);
    var qty = null, itemName = '';
    
    for (var len = 3; len >= 1; len--) {
        if (words.length < len + 1) continue;
        var numPhrase = words.slice(-len).join(' ');
        if (len === 2) {
            var parts = numPhrase.split(' ');
            if (numberWords[parts[0]] !== undefined && numberWords[parts[1]] !== undefined) {
                var tens = numberWords[parts[0]];
                var ones = numberWords[parts[1]];
                if (tens >= 20 && ones < 10) { qty = tens + ones; itemName = words.slice(0, words.length - len).join(' '); break; }
            }
        }
        if (numberWords[numPhrase] !== undefined) { qty = numberWords[numPhrase]; itemName = words.slice(0, words.length - len).join(' '); break; }
    }
    
    if (qty === null) {
        for (var i = words.length - 1; i >= 0; i--) {
            var n = parseFloat(words[i]);
            if (!isNaN(n)) { qty = n; itemName = words.slice(0, i).join(' '); break; }
            if (numberWords[words[i]] !== undefined) { qty = numberWords[words[i]]; itemName = words.slice(0, i).join(' '); break; }
        }
    }
    
    if (qty === null || !itemName) { mToast('warning', 'Could not understand. Try again.'); return; }
    
    itemName = itemName.trim().toLowerCase();
    var found = inv.find(function(it) { return it.name.toLowerCase() === itemName; });
    if (!found) found = inv.find(function(it) { return it.name.toLowerCase().indexOf(itemName) !== -1; });
    if (!found) found = inv.find(function(it) { return itemName.indexOf(it.name.toLowerCase().split(' ')[0]) !== -1; });
    
    if (found) {
        found.quantity = qty;
        found.value = qty * found.cost;
        found.status = qty === 0 ? 'out-of-stock' : qty <= found.reorder ? 'low-stock' : 'in-stock';
        
        var countInput = document.getElementById('mcount-' + found.id);
        if (countInput) countInput.value = qty;
        
        mLogAction('Voice Count (Mobile)', found.name + ': ' + qty + ' ' + found.unit);
        saveMobileData();
        mToast('success', '✓ ' + found.name + ': ' + qty + ' ' + found.unit);
    } else {
        mToast('warning', '"' + itemName + '" not found');
    }
}

