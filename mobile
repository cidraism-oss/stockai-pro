function mUpdateCount(id) {
    var ent = M.entities[M.activeEntity];
    var item = (M.inventory[ent.id] || []).find(function(i) { return i.id === id; });
    if (!item) return;
    var newQty = parseFloat(document.getElementById('mcount-' + id).value) || 0;
    var v = newQty - item.quantity;
    var vClass = v === 0 ? 'zero' : v > 0 ? 'pos' : 'neg';
    var varEl = document.getElementById('mvar-' + id);
    if (varEl) {
        varEl.className = 'm-count-variance ' + vClass;
        varEl.textContent = (v > 0 ? '+' : '') + v;
    }
}

function mAdjustCount(id) {
    var ent = M.entities[M.activeEntity];
    var item = (M.inventory[ent.id] || []).find(function(i) { return i.id === id; });
    if (!item) return;
    var newQty = parseFloat(document.getElementById('mcount-' + id).value);
    if (isNaN(newQty)) return;
    item.quantity = newQty;
    item.value = newQty * item.cost;
    item.status = newQty === 0 ? 'out-of-stock' : newQty <= item.reorder ? 'low-stock' : 'in-stock';
    mLogAction('Stock Adjusted (Mobile)', item.name + ': ' + newQty + ' ' + item.unit);
    saveMobileData();
    mToast('success', item.name + ' adjusted');
}

