<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StockAI-Pro — Customer Portal</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<style>
:root{--teal-dark:#0d4a5c;--teal-mid:#1a8ba8;--teal-light:#4dbdd5;--teal-pale:#a0e9f8;--bg:#f0f7f9;--bg-alt:#e4f1f5;--white:#fff;--text-dark:#0d4a5c;--text-mid:#2a5f70;--text-light:#5a8a96;--text-muted:#8aabb5;--gold:#f59e0b;--gold-dark:#d97706;--success:#2ea871;--danger:#c94545;--warning:#d4a017;--info:#2b8eb3;--border:#c4dde4;--border-light:#e0eff3;--shadow:0 4px 20px rgba(13,74,92,.08);--shadow-lg:0 12px 50px rgba(13,74,92,.15);--radius:14px;--radius-sm:8px}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--text-dark);min-height:100vh}

/* HEADER */
.portal-header{background:linear-gradient(90deg,var(--teal-dark),var(--teal-mid));padding:14px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 20px rgba(0,0,0,.15)}
.portal-logo{display:flex;align-items:center;gap:10px;color:#fff;text-decoration:none;font-size:1.2rem;font-weight:900;letter-spacing:1px}
.portal-logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--teal-light),var(--teal-mid));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.95rem}
.portal-nav{display:flex;gap:14px;align-items:center}
.portal-nav a{color:rgba(255,255,255,.85);text-decoration:none;font-size:.85rem;font-weight:500;transition:.2s;padding:6px 12px;border-radius:6px}
.portal-nav a:hover{background:rgba(255,255,255,.15);color:#fff}
.portal-nav .btn-app{background:var(--gold);color:#fff;font-weight:600;border-radius:8px;padding:8px 16px}
.portal-nav .btn-app:hover{background:var(--gold-dark)}

/* LOGIN SCREEN */
.login-screen{min-height:calc(100vh - 60px);display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0d4a5c 0%,#1a8ba8 50%,#0d4a5c 100%);padding:40px 20px}
.login-card{background:#fff;border-radius:24px;padding:44px 48px;width:440px;max-width:95vw;box-shadow:0 20px 60px rgba(0,0,0,.25);text-align:center}
.login-card h2{font-size:1.5rem;font-weight:800;color:var(--text-dark);margin-bottom:4px}
.login-card .sub{font-size:.88rem;color:var(--text-light);margin-bottom:28px}
.login-field{margin-bottom:18px;text-align:left}
.login-field label{font-size:.82rem;color:var(--text-mid);font-weight:600;display:block;margin-bottom:5px}
.login-field input{width:100%;padding:12px 14px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:.95rem;font-family:inherit;color:var(--text-dark);transition:.2s}
.login-field input:focus{outline:none;border-color:var(--teal-mid);box-shadow:0 0 0 3px rgba(26,139,168,.1)}
.btn-login{width:100%;padding:13px;background:linear-gradient(135deg,var(--teal-mid),var(--teal-dark));color:#fff;border:none;border-radius:var(--radius-sm);font-size:1rem;font-weight:600;cursor:pointer;margin-top:10px;transition:.3s;font-family:inherit}
.btn-login:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(26,139,168,.4)}
.login-footer{margin-top:20px;font-size:.82rem;color:var(--text-light)}
.login-footer a{color:var(--teal-mid);text-decoration:none;font-weight:600}

/* PORTAL DASHBOARD */
.portal-body{max-width:1200px;margin:0 auto;padding:28px 24px}
.portal-welcome{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:14px}
.portal-welcome h1{font-size:1.8rem;font-weight:800;color:var(--text-dark)}
.portal-welcome h1 span{color:var(--teal-mid)}
.portal-welcome p{font-size:.9rem;color:var(--text-light);margin-top:4px}
.portal-actions{display:flex;gap:10px}
.btn-portal{padding:10px 20px;border-radius:var(--radius-sm);font-size:.88rem;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:8px;font-family:inherit;transition:.3s;border:none}
.btn-portal.primary{background:var(--teal-mid);color:#fff}
.btn-portal.primary:hover{background:var(--teal-dark);transform:translateY(-2px)}
.btn-portal.outline{background:transparent;color:var(--text-mid);border:1px solid var(--border)}
.btn-portal.outline:hover{border-color:var(--teal-mid);color:var(--teal-mid)}
.btn-portal.gold{background:var(--gold);color:#fff}
.btn-portal.gold:hover{background:var(--gold-dark)}
.btn-portal.danger{background:var(--danger);color:#fff}
.btn-portal.danger:hover{background:#a83232}

/* PORTAL STATS */
.portal-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px}
.portal-stat{background:#fff;border-radius:var(--radius);padding:20px;box-shadow:var(--shadow);border-left:4px solid var(--teal-mid);transition:.3s}
.portal-stat:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg)}
.portal-stat small{font-size:.75rem;color:var(--text-light);display:block;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;font-weight:600}
.portal-stat strong{font-size:1.6rem;font-weight:800;color:var(--text-dark);display:block}
.portal-stat.gold{border-left-color:var(--gold)}
.portal-stat.green{border-left-color:var(--success)}
.portal-stat.blue{border-left-color:var(--info)}

/* SECTIONS */
.portal-section{background:#fff;border-radius:var(--radius);padding:24px;box-shadow:var(--shadow);margin-bottom:20px;position:relative}
.portal-section::before{content:'';position:absolute;left:0;top:20px;bottom:20px;width:4px;background:var(--teal-mid);border-radius:0 4px 4px 0}
.section-title{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-left:10px}
.section-title h3{font-size:1.1rem;font-weight:700;color:var(--text-dark);display:flex;align-items:center;gap:8px}
.section-title h3 i{color:var(--teal-mid)}

/* ENTITY CARDS */
.entity-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;padding-left:10px}
.entity-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;transition:.3s;position:relative}
.entity-card:hover{border-color:var(--teal-mid);box-shadow:var(--shadow)}
.entity-card-header{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.entity-avatar{width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,var(--teal-mid),var(--teal-dark));color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:700;flex-shrink:0}
.entity-card-name{font-weight:700;font-size:1rem;color:var(--text-dark)}
.entity-card-plan{font-size:.75rem;padding:3px 10px;border-radius:12px;font-weight:600;display:inline-block;margin-top:2px}
.entity-card-plan.starter{background:rgba(26,139,168,.1);color:var(--teal-mid)}
.entity-card-plan.professional{background:rgba(245,158,11,.1);color:var(--gold-dark)}
.entity-card-plan.enterprise{background:rgba(156,39,176,.1);color:#9c27b0}
.entity-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.entity-info-item{font-size:.78rem;color:var(--text-mid)}
.entity-info-item strong{display:block;color:var(--text-dark);font-size:.85rem}
.entity-card-actions{display:flex;gap:8px;flex-wrap:wrap}
.entity-card-actions button{flex:1;min-width:80px}
.entity-status{position:absolute;top:14px;right:14px;width:10px;height:10px;border-radius:50%;background:var(--success)}
.entity-status.inactive{background:var(--danger)}

/* INVOICE TABLE */
.invoice-table{width:100%;border-collapse:collapse;margin-top:12px}
.invoice-table th{padding:10px 14px;text-align:left;font-size:.75rem;font-weight:600;color:var(--text-mid);background:var(--bg);border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:.5px}
.invoice-table td{padding:10px 14px;font-size:.85rem;color:var(--text-dark);border-bottom:1px solid var(--border-light)}
.invoice-table tbody tr:hover{background:var(--bg)}
.invoice-badge{display:inline-block;padding:3px 10px;border-radius:12px;font-size:.7rem;font-weight:600}
.invoice-badge.paid{background:rgba(46,168,113,.12);color:var(--success)}
.invoice-badge.pending{background:rgba(212,160,23,.12);color:var(--warning)}
.invoice-badge.overdue{background:rgba(201,69,69,.12);color:var(--danger)}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(13,74,92,.5);z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px}
.modal-box{background:#fff;border-radius:var(--radius);width:600px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:var(--shadow-lg);animation:modIn .3s ease}
@keyframes modIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
.modal-header{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.modal-header h2{font-size:1.1rem;font-weight:700;color:var(--text-dark)}
.modal-close{background:none;border:none;color:var(--text-mid);font-size:1.1rem;cursor:pointer;padding:8px}
.modal-body{padding:20px 24px}
.modal-footer{padding:14px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px}

/* FORM */
.form-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-bottom:14px}
.form-field{display:flex;flex-direction:column;gap:5px}
.form-field.full{grid-column:1/-1}
.form-field label{font-size:.82rem;color:var(--text-mid);font-weight:600}
.form-field input,.form-field select,.form-field textarea{padding:10px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text-dark);font-size:.9rem;font-family:inherit}
.form-field input:focus,.form-field select:focus{outline:none;border-color:var(--teal-mid);box-shadow:0 0 0 3px rgba(26,139,168,.1)}

/* DISCLAIMER */
.disclaimer-box{background:rgba(245,158,11,.08);border:1px solid var(--gold);border-radius:var(--radius-sm);padding:16px;margin:16px 0}
.disclaimer-box h4{font-size:.9rem;color:var(--gold-dark);margin-bottom:8px;display:flex;align-items:center;gap:6px}
.disclaimer-box p{font-size:.82rem;color:var(--text-mid);line-height:1.6;margin-bottom:10px}
.disclaimer-check{display:flex;align-items:flex-start;gap:8px;font-size:.82rem;color:var(--text-dark);cursor:pointer}
.disclaimer-check input{accent-color:var(--teal-mid);width:16px;height:16px;margin-top:2px;flex-shrink:0}

/* PLAN SELECTOR */
.plan-selector{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:14px 0}
.plan-option{padding:16px;border:2px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;text-align:center;transition:.3s}
.plan-option:hover{border-color:var(--teal-mid);background:var(--bg)}
.plan-option.selected{border-color:var(--gold);background:rgba(245,158,11,.05);box-shadow:0 0 0 3px rgba(245,158,11,.15)}
.plan-option h4{font-size:.9rem;color:var(--text-dark);margin-bottom:4px}
.plan-option .price{font-size:1.4rem;font-weight:900;color:var(--teal-mid)}
.plan-option .per{font-size:.7rem;color:var(--text-light)}

/* TOAST */
.toast-wrap{position:fixed;bottom:24px;right:24px;z-index:10000;display:flex;flex-direction:column;gap:8px}
.toast{background:#fff;padding:12px 18px;border-radius:var(--radius-sm);box-shadow:var(--shadow-lg);display:flex;align-items:center;gap:10px;min-width:280px;animation:tIn .3s ease;border-left:4px solid var(--teal-mid)}
@keyframes tIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
.toast.success{border-left-color:var(--success)}.toast.error{border-left-color:var(--danger)}.toast.info{border-left-color:var(--info)}
.toast i{font-size:1rem}.toast.success i{color:var(--success)}.toast.error i{color:var(--danger)}.toast.info i{color:var(--info)}
.toast span{flex:1;font-size:.88rem;color:var(--text-dark)}.toast button{background:none;border:none;color:var(--text-muted);cursor:pointer}

.hidden{display:none!important}
@media(max-width:768px){.portal-welcome{flex-direction:column;text-align:center}.portal-actions{justify-content:center}.entity-cards{grid-template-columns:1fr}.plan-selector{grid-template-columns:1fr}.portal-nav{gap:8px}.portal-nav a{font-size:.78rem;padding:4px 8px}}
</style>
</head>
