function renderPortalStats() {
    document.getElementById('portal-user-name').textContent = P.user.name;
    
    const activeEntities = P.entities.filter(e => e.status === 'active');
    document.getElementById('portal-entity-count').textContent = activeEntities.length;
    
    const plans = {};
    activeEntities.forEach(e => {
        if (!plans[e.plan]) plans[e.plan] = 0;
        plans[e.plan]++;
    });
    const mainPlan = Object.keys(plans).sort((a,b) => plans[b]-plans[a])[0];
    document.getElementById('portal-plan-name').textContent = mainPlan ? PLANS[mainPlan].name : 'None';
    
    const monthlyTotal = activeEntities.reduce((s, e) => s + (PLANS[e.plan] ? PLANS[e.plan].price : 0), 0);
