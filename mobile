function mToast(type, msg) {
    var icons = {success:'check-circle',error:'times-circle',info:'info-circle',warning:'exclamation-triangle'};
    var t = document.createElement('div');
    t.className = 'm-toast ' + type;
    t.innerHTML = '<i class="fas fa-' + (icons[type] || 'info-circle') + '"></i><span>' + msg + '</span><button onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>';
    document.getElementById('m-toast-wrap').appendChild(t);
    setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 4000);
}

