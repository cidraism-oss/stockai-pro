function calcDeliveryETA(deliveryDays) {
    if (!deliveryDays || deliveryDays.length === 0) return null;
    var DAYS = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    var today = new Date().getDay();
    var minDays = 7;
    deliveryDays.forEach(function(dayName) {
        var dayIdx = DAYS.indexOf(dayName);
        if (dayIdx === -1) return;
        var diff = dayIdx - today;
        if (diff <= 0) diff += 7;
        if (diff < minDays) minDays = diff;
    });
    return minDays;
}

function mLogAction(action, details) {
    if (!M.user) return;
    var ent = M.entities[M.activeEntity] || M.entities[0];
    if (!ent) return;
    if (!M.userLogs[ent.id]) M.userLogs[ent.id] = [];
    var now = new Date();
    M.userLogs[ent.id].unshift({
        user: M.user.name,
        role: M.user.role,
        action: action,
        details: details,
        date: now.toLocaleDateString('en-ZA'),
        time: now.toLocaleTimeString('en-ZA'),
        device: 'Mobile — ' + navigator.platform
    });
    if (M.userLogs[ent.id].length > 200) M.userLogs[ent.id] = M.userLogs[ent.id].slice(0, 200);
}

function mFmt(n) {
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
    return n.toFixed(0);
}

function mStatusText(s) {
