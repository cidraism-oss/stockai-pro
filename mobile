<script>
// ============ MOBILE STATE ============
var M = {
    user: null,
    entities: [],
    activeEntity: 0,
    isGlobalMode: false,
    currentPage: 'dashboard',
    inventory: {},
    purchases: {},
    wastage: {},
    suppliers: {},
    users: {},
    menuItems: {},
    cashups: {},
    notifs: [],
    activities: {},
    pendingPOs: {},
    internalTransfers: [],
    billing: null,
    userLogs: {}
};

var STORAGE_KEY = 'stockai_pro_v5';
var SESSION_TIMEOUT = 15 * 60 * 1000;
var lastMobileActivity = Date.now();

// PERMISSIONS (same as web app)
var KITCHEN_CATS = ['Proteins','Vegetables','Dairy','Dry Goods','Frozen','Bakery'];
var BAR_CATS = ['Beverages'];
var PERMS = {
    'Owner': { all:true, canAccessGlobal:true, pages:['dashboard','stock-count','purchases','inventory','reports','notifications'], categories:'all' },
    'General Manager': { all:true, canAccessGlobal:false, pages:['dashboard','stock-count','purchases','inventory','reports','notifications'], categories:'all' },
    'Area Manager': { all:true, canAccessGlobal:false, pages:['dashboard','stock-count','purchases','inventory','reports','notifications'], categories:'all' },
    'Operations Manager': { all:true, canAccessGlobal:false, pages:['dashboard','stock-count','purchases','inventory','reports','notifications'], categories:'all' },
    'Manager': { pages:['dashboard','stock-count','purchases','inventory','reports'], categories:'all' },
    'Stock Controller': { pages:['dashboard','stock-count','purchases','inventory','reports'], categories:'all' },
    'Kitchen Manager': { pages:['dashboard','stock-count','purchases','inventory','reports'], categories:KITCHEN_CATS, dashboardLabel:'Kitchen' },
    'Bar Manager': { pages:['dashboard','stock-count','purchases','inventory','reports'], categories:BAR_CATS, dashboardLabel:'Bar' },
    'Floor Supervisor': { pages:['stock-count'], categories:'all' },
    'Bar Supervisor': { pages:['stock-count'], categories:BAR_CATS }
};

// ============ INIT ============
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
        document.getElementById('splash').style.opacity = '0';
        setTimeout(function() {
            document.getElementById('splash').classList.add('hidden');
            loadMobileData();
        }, 500);
    }, 2000);
    
    // Session timeout
    ['touchstart','click','scroll'].forEach(function(evt) {
        document.addEventListener(evt, function() { lastMobileActivity = Date.now(); }, {passive:true});
    });
    setInterval(checkMobileSession, 30000);
    
    // Portal sync
    setInterval(checkMobilePortalSync, 5000);
    window.addEventListener('storage', function(e) {
        if (e.key === STORAGE_KEY || e.key === 'stockai_portal_pending') {
            setTimeout(function() { loadMobileData(); }, 500);
        }
    });
});

function loadMobileData() {
    try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (raw) {
            var d = JSON.parse(raw);
            M.entities = d.entities || [];
            M.inventory = d.inventory || {};
            M.purchases = d.purchases || {};
            M.wastage = d.wastage || {};
            M.suppliers = d.suppliers || {};
            M.users = d.users || {};
            M.menuItems = d.menuItems || {};
            M.cashups = d.cashups || {};
            M.notifs = d.notifs || [];
            M.activities = d.activities || {};
            M.pendingPOs = d.pendingPOs || {};
            M.internalTransfers = d.internalTransfers || [];
            M.billing = d.billing || null;
            M.userLogs = d.userLogs || {};
        }
    } catch(e) { console.warn('Load error:', e); }
    
    // Always show login screen — user must log in each time
    document.getElementById('m-login').classList.remove('hidden');
}
function saveMobileData() {
    try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (raw) {
            var d = JSON.parse(raw);
            d.inventory = M.inventory;
            d.purchases = M.purchases;
            d.notifs = M.notifs;
            d.userLogs = M.userLogs;
            d.pendingPOs = M.pendingPOs;
            d.billing = M.billing;
            localStorage.setItem(STORAGE_KEY, JSON.stringify(d));
        }
    } catch(e) {}
}

// ============ LOGIN ============
function mLogin(e) {
    e.preventDefault();
    var name = document.getElementById('m-username').value || 'User';
    var role = document.getElementById('m-role').value;
    
    if (!name.trim()) {
        mToast('error', 'Please enter your username');
        return;
    }
    
    M.user = { name:name, role:role, assignedEntity:0 };
    
    // If no entities exist, create a default one so the app works
    if (M.entities.length === 0) {
        M.entities = [{
            id: 'ENT-MOBILE-' + Date.now(),
            name: name + '\'s Restaurant',
            contact: name,
            phone: '',
            email: '',
            address: '',
            vat: '',
            foodCostTarget: 28,
            sections: ['Walk-in Fridge', 'Walk-in Freezer', 'Dry Store', 'Bar'],
            plan: 'professional'
        }];
        
        // Generate demo data
        generateMobileData(M.entities[0]);
        
        mToast('success', 'Welcome! Demo data loaded. Use the full web app at stockai.co.za/app.html to set up properly.');
    }
    
    mLogAction('Login', name + ' logged in on mobile as ' + role);
    
    document.getElementById('m-login').classList.add('hidden');
    showMobileEntitySelector();
}

function generateMobileData(ent) {
    if (M.inventory[ent.id]) return;
    
    var items = [
        {name:'Chicken Breast',cat:'Proteins',unit:'kg',cost:89.90,loc:'Walk-in Fridge'},
        {name:'Beef Fillet',cat:'Proteins',unit:'kg',cost:249.90,loc:'Walk-in Fridge'},
        {name:'Fresh Salmon',cat:'Proteins',unit:'kg',cost:299.90,loc:'Walk-in Fridge'},
        {name:'Prawns',cat:'Proteins',unit:'kg',cost:320,loc:'Walk-in Freezer'},
        {name:'Tomatoes',cat:'Vegetables',unit:'kg',cost:32.90,loc:'Walk-in Fridge'},
        {name:'Baby Spinach',cat:'Vegetables',unit:'kg',cost:89.90,loc:'Walk-in Fridge'},
        {name:'Mushrooms',cat:'Vegetables',unit:'kg',cost:54.90,loc:'Walk-in Fridge'},
        {name:'Brown Onions',cat:'Vegetables',unit:'kg',cost:14.90,loc:'Dry Store'},
        {name:'Potatoes',cat:'Vegetables',unit:'kg',cost:18.90,loc:'Dry Store'},
        {name:'Full Cream Milk',cat:'Dairy',unit:'liter',cost:19.90,loc:'Walk-in Fridge'},
        {name:'Cheddar Cheese',cat:'Dairy',unit:'kg',cost:109.90,loc:'Walk-in Fridge'},
        {name:'Eggs',cat:'Dairy',unit:'dozen',cost:54.90,loc:'Walk-in Fridge'},
        {name:'Butter',cat:'Dairy',unit:'kg',cost:89.90,loc:'Walk-in Fridge'},
        {name:'Basmati Rice',cat:'Dry Goods',unit:'kg',cost:34.90,loc:'Dry Store'},
        {name:'Pasta',cat:'Dry Goods',unit:'kg',cost:24.90,loc:'Dry Store'},
        {name:'Olive Oil',cat:'Dry Goods',unit:'liter',cost:129.90,loc:'Dry Store'},
        {name:'Coca-Cola',cat:'Beverages',unit:'case',cost:149.90,loc:'Bar'},
        {name:'House Red Wine',cat:'Beverages',unit:'each',cost:89.90,loc:'Bar'},
        {name:'Craft Beer',cat:'Beverages',unit:'case',cost:299.90,loc:'Bar'},
        {name:'Frozen Chips',cat:'Frozen',unit:'kg',cost:34.90,loc:'Walk-in Freezer'},
        {name:'Burger Buns',cat:'Bakery',unit:'dozen',cost:39.90,loc:'Dry Store'}
    ];
    
    M.inventory[ent.id] = items.filter(function(it) {
        return ent.sections.indexOf(it.loc) !== -1;
    }).map(function(it, i) {
        var qty = Math.floor(Math.random() * 80 + 2);
        var reorder = Math.floor(Math.random() * 15 + 5);
        var status = qty === 0 ? 'out-of-stock' : qty <= reorder ? 'low-stock' : 'in-stock';
        return {
            id: 'ITM-MOB-' + i,
            sku: 'FD-' + Math.floor(Math.random() * 90000 + 10000),
            name: it.name,
            category: it.cat,
            unit: it.unit,
            quantity: qty,
            cost: it.cost,
            lastCost: it.cost,
            value: qty * it.cost,
            location: it.loc,
            status: status,
            reorder: reorder,
            supplier: 'Default Supplier'
        };
    });
    
    M.suppliers[ent.id] = [
        {name:'FreshFarm Produce',type:'Vegetables',orders:48,rating:'4.8',onTime:'96%',phone:'+27 21 555 0101',deliveryDays:['Monday','Wednesday','Friday']},
        {name:'SA Meat Wholesalers',type:'Proteins',orders:35,rating:'4.5',onTime:'92%',phone:'+27 11 555 0202',deliveryDays:['Tuesday','Thursday']}
    ];
    
    M.purchases[ent.id] = [];
    M.wastage[ent.id] = [];
    M.users[ent.id] = [{id:'usr-mob-1',name:ent.contact,role:'General Manager'}];
    M.activities[ent.id] = [
        {type:'add',icon:'fa-plus',item:'Chicken Breast',action:'received',user:ent.contact,time:'Just now'},
        {type:'update',icon:'fa-edit',item:'Tomatoes',action:'count adjusted',user:ent.contact,time:'5m ago'}
    ];
    M.pendingPOs[ent.id] = [];
    M.notifs = [{type:'success',title:'Welcome!',text:'Your mobile app is ready. Use voice counting for faster stock takes!',time:'now',unread:true}];
    M.userLogs[ent.id] = [];
    
    // Save to localStorage
    try {
        var data = {
            entities: M.entities,
            inventory: M.inventory,
            purchases: M.purchases,
            wastage: M.wastage,
            suppliers: M.suppliers,
            users: M.users,
            menuItems: M.menuItems || {},
            cashups: M.cashups || {},
            notifs: M.notifs,
            activities: M.activities,
            pendingPOs: M.pendingPOs,
            internalTransfers: M.internalTransfers || [],
            billing: M.billing,
            userLogs: M.userLogs
        };
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch(e) { console.warn('Save error:', e); }
}
function mLogout() {
    mLogAction('Logout', M.user.name + ' logged out from mobile');
    M.user = null;
    M.isGlobalMode = false;
    document.getElementById('m-app').classList.add('hidden');
    document.getElementById('m-entity-screen').classList.add('hidden');
    document.getElementById('m-login').classList.remove('hidden');
    toggleSideMenu();
    mToast('info', 'Logged out');
}

// ============ ENTITY SELECTOR ============
function showMobileEntitySelector() {
    document.getElementById('m-login').classList.add('hidden');
    document.getElementById('m-app').classList.add('hidden');
    document.getElementById('m-entity-screen').classList.remove('hidden');
    
    var perms = PERMS[M.user.role] || PERMS['Stock Controller'];
    var visible = M.entities;
    
    if (!perms.canAccessGlobal && M.user.role !== 'Owner' && M.user.role !== 'Area Manager' && M.user.role !== 'Operations Manager') {
        var assigned = M.user.assignedEntity || 0;
        visible = [M.entities[assigned] || M.entities[0]];
    }
    
    var html = '';
    visible.forEach(function(ent) {
        var idx = M.entities.indexOf(ent);
        html += '<div class="m-entity-card" onclick="selectMobileEntity(' + idx + ',false)"><div class="m-entity-avatar">' + ent.name.charAt(0) + '</div><div><h3>' + ent.name + '</h3><p>' + (ent.contact || '') + ' • FC: ' + ent.foodCostTarget + '%</p></div></div>';
    });
    
    if (perms.canAccessGlobal && M.entities.length >= 2) {
        html += '<div class="m-entity-card global" onclick="selectMobileEntity(-1,true)"><div class="m-entity-avatar"><i class="fas fa-globe"></i></div><div><h3>👑 GLOBAL VIEW</h3><p>All ' + M.entities.length + ' Entities</p></div></div>';
    }
    
    document.getElementById('m-entity-cards').innerHTML = html;
}

function selectMobileEntity(idx, isGlobal) {
    M.isGlobalMode = isGlobal;
    M.activeEntity = idx;
    document.getElementById('m-entity-screen').classList.add('hidden');
    enterMobileApp();
}

function switchMobileEntity() {
    toggleSideMenu();
    document.getElementById('m-app').classList.add('hidden');
    showMobileEntitySelector();
}

// ============ ENTER APP ============
function enterMobileApp() {
    document.getElementById('m-app').classList.remove('hidden');
    
    var entityName = M.isGlobalMode ? '👑 Global View' : (M.entities[M.activeEntity] ? M.entities[M.activeEntity].name : 'Entity');
    document.getElementById('m-header-entity').textContent = entityName;
    
    document.getElementById('m-side-user').textContent = M.user.name;
    document.getElementById('m-side-role').textContent = M.user.role;
    
    buildSideMenu();
    updateNotifCount();
    mNavigate('dashboard');
    
    // Check payment status
    setTimeout(checkMobilePayment, 1500);
}

function buildSideMenu() {
    var perms = PERMS[M.user.role] || PERMS['Stock Controller'];
    var links = [
        {page:'dashboard',icon:'fa-chart-pie',label:'Dashboard'},
        {page:'stock-count',icon:'fa-clipboard-list',label:'Stock Count'},
        {page:'purchases',icon:'fa-shopping-cart',label:'Purchases'},
        {page:'inventory',icon:'fa-box',label:'Inventory'}
    ];
    
    if (perms.all || (perms.pages && perms.pages.includes('reports'))) {
