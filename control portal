// ============ COMMUNICATION WITH WEB APP ============
function notifyWebApp(action, data) {
    // Store pending actions for the web app to pick up
    try {
        let pending = JSON.parse(localStorage.getItem('stockai_portal_pending') || '[]');
        pending.push({
            action: action,
            data: data,
            timestamp: new Date().toISOString(),
            processed: false
        });
        localStorage.setItem('stockai_portal_pending', JSON.stringify(pending));
    } catch(e) {
        console.warn('Could not notify web app:', e);
    }
}

function sendNotificationEmail(type, data) {
    // Prepare email content based on type
    let subject = '';
    let body = '';
    const ownerEmail = P.user.email || 'cidraism@gmail.com';
    
    if (type === 'new_entity') {
        subject = `StockAI-Pro — New Entity Created: ${data.name}`;
        body = `New entity "${data.name}" has been purchased and added to your account.\n\nPlan: ${PLANS[data.plan]?.name || data.plan}\nContact: ${data.contact}\n\nPlease open the StockAI-Pro app to complete the entity setup.`;
    } else if (type === 'plan_change') {
        subject = `StockAI-Pro — Plan ${data.changeType}: ${data.entityName}`;
        body = `Plan change confirmed for "${data.entityName}".\n\nFrom: ${data.oldPlan}\nTo: ${data.newPlan}\nType: ${data.changeType}\nEffective: ${data.effectiveDate}\n\n30-day notice period applies.`;
    } else if (type === 'entity_cancelled') {
        subject = `StockAI-Pro — Entity Cancellation: ${data.entityName}`;
        body = `Entity "${data.entityName}" has been cancelled.\n\nEffective date: ${data.effectiveDate}\nReason: ${data.reason || 'Not specified'}\n\n30-day notice period applies. You can reactivate within 90 days.`;
    } else if (type === 'entity_reactivated') {
        subject = `StockAI-Pro — Entity Reactivated: ${data.entityName}`;
        body = `Entity "${data.entityName}" has been reactivated. Billing resumes immediately.`;
    }
    
    // Log the email (in production this would use SendGrid/Resend)
    console.log(`📧 Email notification: ${type}`, {to: ownerEmail, subject, body});
    console.log(`📧 Admin notification: ${type}`, {to: 'cidraism@gmail.com', subject: '[ADMIN] ' + subject, body});
    
    // For now, we can open mailto as a fallback demonstration
    // In Phase 2 (online), this will use a real email service
}

