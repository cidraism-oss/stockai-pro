// Add forgot password to mobile login
setTimeout(function() {
    var loginCard = document.querySelector('.m-login-card');
    if (loginCard) {
        var forgotDiv = document.createElement('div');
        forgotDiv.style.cssText = 'text-align:center;margin-top:14px;padding-top:14px;border-top:1px solid #e0eff3';
        forgotDiv.innerHTML = '<a href="#" onclick="mShowForgotPassword();return false" style="color:#1a8ba8;font-size:.85rem;text-decoration:none;font-weight:500"><i class="fas fa-key"></i> Forgot password?</a>';
        loginCard.appendChild(forgotDiv);
    }
}, 1000);

function mShowForgotPassword() {
    var email = prompt('Enter your email address to receive a password reset link:');
    if (!email || !email.trim()) return;
    
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        mToast('error', 'Please enter a valid email');
        return;
    }
    
    auth.sendPasswordResetEmail(email)
        .then(function() {
            mToast('success', '📧 Reset link sent to ' + email);
        })
        .catch(function(err) {
            if (err.code === 'auth/user-not-found') {
                mToast('error', 'No account found. Contact: 079 044 0508');
            } else {
                mToast('error', err.message);
            }
        });
}

