// ============ PAYMENT CHECK ============
function checkMobilePayment() {
    if (!M.billing || !M.user) return;
    
    var now = new Date();
    var dueDate = new Date(M.billing.nextDueDate);
    var diffMs = dueDate.getTime() - now.getTime();
    var diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));
    var today = now.toISOString().split('T')[0];
    
    if (M.billing.dismissedToday === today && diffDays > 0) return;
    
    if (diffDays <= 4 || diffDays < 0) {
        showMobilePaymentReminder(diffDays, dueDate);
    }
}

function showMobilePaymentReminder(daysLeft, dueDate) {
    var isOverdue = daysLeft < 0;
    var headerClass = isOverdue ? 'danger' : 'warning';
    var title = isOverdue ? '⚠️ Payment Overdue' : '💳 Payment Reminder';
    var msg = isOverdue ? 'Your payment is ' + Math.abs(daysLeft) + ' day(s) overdue. Please pay to continue.' : 'Your payment is due in ' + daysLeft + ' day(s).';
    
    var planPrices = {starter:499, professional:899, enterprise:1499};
    var activeEnts = M.entities.filter(function(e) { return e.status !== 'cancelled'; });
    var total = 0;
    activeEnts.forEach(function(e) { total += planPrices[e.plan] || 899; });
    
    var closeBtn = isOverdue ? '' : '<button style="background:var(--bg);color:var(--text-mid)" onclick="dismissMobilePayment()">Later</button>';
    
    var overlay = document.createElement('div');
    overlay.className = 'm-payment-overlay';
    overlay.id = 'm-payment-overlay';
    overlay.innerHTML = '<div class="m-payment-modal"><div class="m-payment-header ' + headerClass + '"><div style="font-size:2.5rem;margin-bottom:6px">' + (isOverdue ? '⚠️' : '💳') + '</div><h2>' + title + '</h2><p>' + msg + '</p></div><div class="m-payment-body"><div class="m-payment-amount">R' + total.toLocaleString() + '</div><p style="text-align:center;font-size:.82rem;color:var(--text-light)">Due: ' + dueDate.toLocaleDateString('en-ZA',{day:'numeric',month:'long',year:'numeric'}) + '</p></div><div class="m-payment-footer">' + closeBtn + '<button style="background:var(--success);color:#fff" onclick="mMakePayment(' + total + ')"><i class="fas fa-credit-card"></i> Pay Now</button></div></div>';
    
