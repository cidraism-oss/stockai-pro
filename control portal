<script>
// ============ PORTAL STATE ============
const PORTAL_KEY = 'stockai_portal';
let P = {
    loggedIn: false,
    user: null,
    entities: [],
    invoices: [],
    notifications: []
};

const PLANS = {
    starter: { name: 'Starter', price: 499, features: '1 entity, 3 users, basic features' },
    professional: { name: 'Professional', price: 899, features: 'Up to 3 entities, unlimited users, AI features' },
    enterprise: { name: 'Enterprise', price: 1499, features: 'Unlimited entities, POS + accounting integration' }
};

// ============ INIT ============
document.addEventListener('DOMContentLoaded', () => {
    loadPortal();
});

function savePortal() {
    try { localStorage.setItem(PORTAL_KEY, JSON.stringify(P)); } catch(e){}
}

function loadPortal() {
    try {
        const raw = localStorage.getItem(PORTAL_KEY);
        if (raw) {
            const d = JSON.parse(raw);
            Object.assign(P, d);
            if (P.loggedIn && P.user) {
                showPortalDashboard();
                return;
            }
        }
    } catch(e){}
    
    // Check if app has existing data we can use
    try {
        const appData = localStorage.getItem('stockai_pro_v5');
        if (appData) {
            const app = JSON.parse(appData);
            if (app.owner && app.entities && app.entities.length > 0) {
                P.user = {
                    name: app.owner.name || 'Customer',
                    email: app.owner.email || '',
                    company: app.owner.groupName || '',
                    phone: app.owner.phone || '',
                    memberSince: new Date().toLocaleDateString('en-ZA')
                };
                P.entities = app.entities.map((ent, idx) => ({
                    id: ent.id,
                    name: ent.name,
                    plan: idx === 0 ? 'professional' : 'starter',
                    status: 'active',
                    contact: ent.contact || '',
                    email: ent.email || '',
                    phone: ent.phone || '',
                    createdDate: new Date().toLocaleDateString('en-ZA')
                }));
                generateInvoices();
            }
        }
    } catch(e){}
}

function generateInvoices() {
    if (P.invoices.length > 0) return;
    P.entities.forEach((ent, idx) => {
        const plan = PLANS[ent.plan];
        for (let m = 0; m < 3; m++) {
            const date = new Date();
            date.setMonth(date.getMonth() - m);
            P.invoices.push({
                id: `INV-${date.getFullYear()}${String(date.getMonth()+1).padStart(2,'0')}-${String(idx+1).padStart(2,'0')}`,
                entityId: ent.id,
                entityName: ent.name,
                plan: plan.name,
                amount: plan.price,
                date: date.toLocaleDateString('en-ZA',{day:'2-digit',month:'short',year:'numeric'}),
                dateRaw: date.toISOString(),
                status: m === 0 ? 'paid' : 'paid'
            });
        }
    });
    savePortal();
}

// ============ LOGIN ============
function portalLogin(e) {
    e.preventDefault();
    const email = document.getElementById('portal-email').value;
    const password = document.getElementById('portal-password').value;
    
    if (!email || !password) { toast('error','Please fill in all fields'); return; }
    
    if (!P.user) {
        P.user = {
            name: 'Customer',
            email: email,
            company: 'My Restaurant Group',
            phone: '',
            memberSince: new Date().toLocaleDateString('en-ZA')
        };
    }
    
    if (P.entities.length === 0) {
        P.entities = [{
            id: 'ENT-PORTAL-' + Date.now(),
            name: 'My Restaurant',
            plan: 'professional',
            status: 'active',
            contact: P.user.name,
            email: email,
            phone: '',
            createdDate: new Date().toLocaleDateString('en-ZA')
        }];
        generateInvoices();
    }
    
    P.loggedIn = true;
    savePortal();
